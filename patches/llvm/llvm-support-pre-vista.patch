+// The processor-group APIs are Win7+. They don't exist on Vista/XP/2000, and a
+// static import would stop clang/lld from LOADING there, so resolve them
+// dynamically (LLVM does the same for PrefetchVirtualMemory). When absent,
+// getProcessorGroups() falls back to a single group from GetSystemInfo and
+// thread-group affinity is skipped -- correct for a single-group system.
+namespace {
+struct ProcGroupApi {
+  using GetLogicalProcessorInformationEx_t =
+      BOOL(WINAPI *)(LOGICAL_PROCESSOR_RELATIONSHIP,
+                     PSYSTEM_LOGICAL_PROCESSOR_INFORMATION_EX, PDWORD);
+  using GetProcessGroupAffinity_t = BOOL(WINAPI *)(HANDLE, PUSHORT, PUSHORT);
+  using GetThreadGroupAffinity_t = BOOL(WINAPI *)(HANDLE, PGROUP_AFFINITY);
+  using SetThreadGroupAffinity_t =
+      BOOL(WINAPI *)(HANDLE, const GROUP_AFFINITY *, PGROUP_AFFINITY);
+  GetLogicalProcessorInformationEx_t GetLogicalProcessorInformationEx = nullptr;
+  GetProcessGroupAffinity_t GetProcessGroupAffinity = nullptr;
+  GetThreadGroupAffinity_t GetThreadGroupAffinity = nullptr;
+  SetThreadGroupAffinity_t SetThreadGroupAffinity = nullptr;
+  ProcGroupApi() {
+    // kernel32 is always mapped, so GetModuleHandleW is safe (no DLL search).
+    HMODULE K = ::GetModuleHandleW(L"kernel32.dll");
+    if (!K)
+      return;
+    GetLogicalProcessorInformationEx =
+        (GetLogicalProcessorInformationEx_t)::GetProcAddress(
+            K, "GetLogicalProcessorInformationEx");
+    GetProcessGroupAffinity = (GetProcessGroupAffinity_t)::GetProcAddress(
+        K, "GetProcessGroupAffinity");
+    GetThreadGroupAffinity = (GetThreadGroupAffinity_t)::GetProcAddress(
+        K, "GetThreadGroupAffinity");
+    SetThreadGroupAffinity = (SetThreadGroupAffinity_t)::GetProcAddress(
+        K, "SetThreadGroupAffinity");
+  }
+};
+static const ProcGroupApi &procGroupApi() {
+  static ProcGroupApi API;
+  return API;
+}
