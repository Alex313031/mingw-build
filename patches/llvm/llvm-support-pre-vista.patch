+  // GetLargePageMinimum is Vista+; resolve it dynamically so the binary loads
+  // on Windows XP/2000. Absent -> 0 -> large pages stay disabled (the existing
+  // !Token fall-through below already handles 0).
+  size_t LargePageMin = 0;
+  if (HMODULE K = ::GetModuleHandleW(L"kernel32.dll")) {
+    using GetLargePageMinimum_t = SIZE_T(WINAPI *)();
+    if (auto Fn = reinterpret_cast<GetLargePageMinimum_t>(
+            ::GetProcAddress(K, "GetLargePageMinimum")))
+      LargePageMin = Fn();
