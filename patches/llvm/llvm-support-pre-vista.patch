+// GetFinalPathNameByHandleW (Vista) and SetFileInformationByHandle (Vista) are
+// resolved dynamically so clang/lld still LOAD on Windows XP/2000, where a
+// static import of either would block process startup. When absent,
+// realPathFromHandle fails soft (its callers ignore the result or fall back)
+// and rename() routes through MoveFileExW by path; remove() already deletes via
+// FILE_FLAG_DELETE_ON_CLOSE, which works on every NT.
+namespace {
+struct VistaFileApi {
+  using GetFinalPathNameByHandleW_t = DWORD(WINAPI *)(HANDLE, LPWSTR, DWORD,
+                                                      DWORD);
+  using SetFileInformationByHandle_t =
+      BOOL(WINAPI *)(HANDLE, FILE_INFO_BY_HANDLE_CLASS, LPVOID, DWORD);
+  GetFinalPathNameByHandleW_t GetFinalPathNameByHandleW = nullptr;
+  SetFileInformationByHandle_t SetFileInformationByHandle = nullptr;
+  VistaFileApi() {
+    // kernel32 is always mapped, so GetModuleHandleW is safe (no DLL search).
+    HMODULE K = ::GetModuleHandleW(L"kernel32.dll");
+    if (!K)
+      return;
+    GetFinalPathNameByHandleW = (GetFinalPathNameByHandleW_t)::GetProcAddress(
+        K, "GetFinalPathNameByHandleW");
+    SetFileInformationByHandle = (SetFileInformationByHandle_t)::GetProcAddress(
+        K, "SetFileInformationByHandle");
+  }
+};
+static const VistaFileApi &vistaFileApi() {
+  static VistaFileApi API;
+  return API;
+}
