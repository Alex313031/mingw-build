+std::string llvm::GetWindowsOSName() {
+  RTL_OSVERSIONINFOEXW info = GetWindowsVer();
+  const ULONG MAJOR = info.dwMajorVersion;
+  const ULONG MINOR = info.dwMinorVersion;
+  const ULONG BUILD = info.dwBuildNumber;
+  const std::string ntver = std::to_string(MAJOR) + "." +
+                            std::to_string(MINOR) + "." + std::to_string(BUILD);
+  switch (MAJOR) {
+  case 4UL:
+    return "Windows NT 4.0 " + ntver;
+  case 5UL:
+    switch (MINOR) {
+    case 0UL:
+      return "Windows 2000 " + ntver;
+    case 1UL:
+      return "Windows XP " + ntver;
+    case 2UL:
+      return "Windows Server 2003/XP x64 " + ntver;
+    default:
+      return "NT " + ntver;
+    }
+  case 6UL:
+    switch (MINOR) {
+    case 0UL:
+      switch (BUILD) {
+      case 6000UL:
+        return "Windows Vista/Server 2008 RTM " + ntver;
+      case 6001UL:
+        return "Windows Vista/Server 2008 SP1 " + ntver;
+      case 6002UL:
+        return "Windows Vista/Server 2008 SP2 " + ntver;
+      case 6003UL:
+        return "Windows Vista/Server 2008 KB4489887 " + ntver;
+      default:
+        return "Windows Vista/Server 2008 " + ntver;
+      }
+    case 1UL:
+      switch (BUILD) {
+      case 7600UL:
+        return "Windows 7/Server 2008 R2 RTM " + ntver;
+      case 7601UL:
+        return "Windows 7/Server 2008 R2 SP1 " + ntver;
+      case 8400UL:
+        return "Windows Home Server 2011 " + ntver;
+      default:
+        return "Windows 7/Server 2008 R2 " + ntver;
+      }
+    case 2UL:
+      return "Windows 8/Server 2012 " + ntver;
+    case 3UL:
+      return "Windows 8.1/Server 2012 R2 " + ntver;
+    default:
+      return "NT " + ntver;
+    }
+  case 10UL:
+    switch (MINOR) {
+    case 0UL:
+      return (BUILD < 22000UL ? "Windows 10 " : "Windows 11 ") + ntver;
+    default:
+      return "NT " + ntver;
+    }
+  default:
+    return "Unknown Windows " + ntver;
+  }
+}
+
+bool llvm::IsSupportedWindows() {
+  static bool is_xp = RunningWindowsXPOrGreater();
+  return is_xp;
+}
+
+bool llvm::IsLegacyWindows() {
+  static bool is_legacy = !RunningWindows7OrGreater();
+  return is_legacy;
+}
+
+bool llvm::RunningWindows2KOrGreater() {
+  // Windows 2000 is version 5.0, service pack 0.
+  return GetWindowsOSVersion() >= llvm::VersionTuple(5, 0, 0, 0);
+}
+
+bool llvm::RunningWindowsXPOrGreater() {
+  // Windows XP is version 5.1, service pack 0.
+  return GetWindowsOSVersion() >= llvm::VersionTuple(5, 1, 0, 0);
+}
+
+bool llvm::RunningWindowsVistaOrGreater() {
+  // Windows Vista is version 6.0, service pack 0.
+  return GetWindowsOSVersion() >= llvm::VersionTuple(6, 0, 0, 0);
+}
+
+bool llvm::RunningWindows7OrGreater() {
+  // Windows 7 is version 6.1, service pack 0.
+  return GetWindowsOSVersion() >= llvm::VersionTuple(6, 1, 0, 0);
+}
+
 bool llvm::RunningWindows8OrGreater() {
   // Windows 8 is version 6.2, service pack 0.
   return GetWindowsOSVersion() >= llvm::VersionTuple(6, 2, 0, 0);
 }
 
+bool llvm::RunningWindows10OrGreater() {
+  // Windows 10 is 10.0, but 11 is too.
+  return GetWindowsOSVersion() >= llvm::VersionTuple(10, 0, 0, 0);
+}
