+++ b/mingw-w64-crt/misc/mkstemp.c
@@ -47,7 +47,7 @@ int __cdecl mkstemp (char *template_name)
     for (i = 0; i <= INT_MAX; i++) {
         for(j = index; j < len; j++) {
             if (rand_s(&r))
-                r = rand() ^ _time32(NULL);
+                r = rand() ^ (unsigned int) _time64 (NULL);
             template_name[j] = letters[r % 62];
